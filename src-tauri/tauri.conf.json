{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DockDuo",
  "version": "0.2.1",
  "identifier": "com.codewithanuj.dockduo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "overlay",
        "url": "index.html",
        "title": "DockDuo",
        "width": 1920,
        "height": 200,
        "x": 0,
        "y": 880,
        "transparent": true,
        "backgroundColor": "#00000000",
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "shadow": false,
        "acceptFirstMouse": true,
        "visible": true
      },
      {
        "label": "onboarding",
        "url": "index.html",
        "title": "Welcome to DockDuo",
        "width": 560,
        "height": 540,
        "center": true,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "skipTaskbar": false
      },
      {
        "label": "bubble_bruce",
        "url": "index.html",
        "title": "DockDuo · Bruce",
        "width": 420,
        "height": 520,
        "x": 100,
        "y": 100,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": true,
        "focus": true,
        "visible": false
      },
      {
        "label": "bubble_jazz",
        "url": "index.html",
        "title": "DockDuo · Jazz",
        "width": 420,
        "height": 520,
        "x": 100,
        "y": 100,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": true,
        "focus": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/anujdevsingh/dockduo/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVENEYzOTNCRjk5RjY4RDgKUldUWWFKLzVPemxQWGExb3laRjNqczZjeUR6OElGa015cDZvanhpUFpDWTNWZEhRYTdYUFVyTWkK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"]
      },
      "webviewInstallMode": { "type": "embedBootstrapper" }
    }
  }
}
