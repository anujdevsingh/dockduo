{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DockDuo",
  "version": "0.1.0",
  "identifier": "com.codewithanuj.dockduo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "overlay",
        "url": "index.html?window=overlay",
        "title": "DockDuo",
        "width": 1920,
        "height": 200,
        "x": 0,
        "y": 880,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "shadow": false,
        "acceptFirstMouse": true,
        "visible": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"]
      },
      "webviewInstallMode": { "type": "embedBootstrapper" }
    }
  }
}
